# ---------------------------------------------------------------------------
# Environment template. Copy to `.env.local` (web) and fill values.
# Validated at boot by packages/config (Zod). Missing/invalid values fail fast.
# NEVER put secrets in NEXT_PUBLIC_* variables — those are shipped to the browser.
# ---------------------------------------------------------------------------

# --- Deployment ---
APP_ENV=local                       # local | staging | production
DEPLOYMENT_MODE=shared              # shared | dedicated
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (public, client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# --- Supabase (SERVER ONLY — never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# --- AI providers (SERVER ONLY) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
EMBEDDINGS_PROVIDER=openai          # openai | gemini

# --- WhatsApp (SERVER ONLY) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# --- Google OAuth (SERVER ONLY) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Observability (SERVER ONLY) ---
SENTRY_DSN=
