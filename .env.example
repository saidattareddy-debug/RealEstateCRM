# ---------------------------------------------------------------------------
# Environment template. Copy to `.env.local` (web) and fill values.
# Validated at boot by packages/config (Zod). Missing/invalid values fail fast.
# NEVER put secrets in NEXT_PUBLIC_* variables — those are shipped to the browser.
# ---------------------------------------------------------------------------

# --- Deployment ---
APP_ENV=local                       # local | staging | production
ENVIRONMENT_NAME=local             # optional operator label used by demo-safety checks
DEPLOYMENT_MODE=shared              # shared | dedicated
DEPLOYMENT_PROFILE=controlled_mvp   # controlled_mvp | full
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Environment identity / preflight (operator-only) ---
# Fill these for hosted staging / production work so preflight can prove that the
# app is pointed at the right Supabase project before any migration is pushed.
STAGING_SUPABASE_PROJECT_REF=
PRODUCTION_SUPABASE_PROJECT_REF=
EXPECTED_SUPABASE_PROJECT_REF=

# --- Safety gates (SERVER ONLY — all default to the SAFE value) ---
# Phase-7A public provider webhook intake. Keep false until go-live.
INTEGRATION_PUBLIC_WEBHOOKS_ENABLED=false   # true | false
# Real-provider draft activation. Turn on only when Anthropic/OpenAI draft paths
# should use live server-side providers; this still does NOT enable customer send.
INTEGRATION_LIVE_PROVIDERS_ENABLED=false    # true | false
LIVE_SEND_MASTER_SWITCH=false               # must stay false in controlled_mvp
RESPONDER_LIVE_SENDING=false                # must stay false in controlled_mvp
BINARY_MEDIA_RETRIEVAL_ENABLED=false        # must stay false in controlled_mvp

# --- Supabase (public, client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# --- Supabase (SERVER ONLY — never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SESSION_SIGNING_SECRET=replace-with-local-session-secret

# --- AI providers (SERVER ONLY) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
EMBEDDINGS_PROVIDER=openai          # openai | gemini

# --- WhatsApp (SERVER ONLY) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# --- Google OAuth (SERVER ONLY) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Observability (SERVER ONLY) ---
SENTRY_DSN=

# --- Demo data (staging only; leave disabled by default) ---
ALLOW_DEMO_DATA_SEED=false
DEMO_SEED_CONFIRMATION=
DEMO_BLOCKED_PROJECT_REFS=
